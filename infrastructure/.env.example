# Copy file này thành `.env` trong cùng thư mục `infrastructure/`:
#   cp .env.example .env
#
# Docker Compose tự đọc `.env` để inject biến môi trường vào container.
# File `.env` không được commit lên git (đã nằm trong .gitignore).

# --- PostgreSQL server (hạ tầng dùng chung, KHÔNG phải DB của một service cụ thể) ---
# Container postgres chỉ cung cấp instance kết nối. Mỗi microservice có database riêng
# (payflow_user_db, payflow_payment_db, ...)

POSTGRES_USER=payflow_user
POSTGRES_PASSWORD=change-me-postgres-password
JWT_SECRET= change-me-jwt-secret-min-256-bits-for-hs256